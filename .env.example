# ─── DATABASE ───────────────────────────────────────────
DATABASE_URL="postgresql://taula:password@localhost:5432/taula_dev?schema=public"
REDIS_URL="redis://localhost:6379"

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-in-production-32"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── MAPBOX ─────────────────────────────────────────────
MAPBOX_SECRET_TOKEN="sk.eyJ1IjoiLi4uIn0..."
MAPBOX_PUBLIC_TOKEN="pk.eyJ1IjoiLi4uIn0..."

# ─── CLOUDINARY ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="taula-ad"
CLOUDINARY_API_KEY="123456789"
CLOUDINARY_API_SECRET="abc123..."

# ─── RESEND (EMAILS) ────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="Taula <hola@taula.ad>"

# ─── FIREBASE (PUSH NOTIFICATIONS) ──────────────────────
FIREBASE_PROJECT_ID="taula-app"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@taula-app.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ─── GOOGLE OAUTH ───────────────────────────────────────
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-..."

# ─── APPLE OAUTH ────────────────────────────────────────
APPLE_CLIENT_ID="ad.taula.app"
APPLE_TEAM_ID="XXXXXXXXXX"
APPLE_KEY_ID="XXXXXXXXXX"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ─── ADMIN ──────────────────────────────────────────────
ADMIN_API_KEY="change-me-admin-key"

# ─── APP ────────────────────────────────────────────────
APP_ENV="development"
API_URL="http://localhost:3000"
PORT="3000"

# ─── MOBILE (Expo) ─────────────────────────────────────
# Opcional: URL base de la API para la app. Si no se define, en desarrollo Expo
# infiere la IP del PC desde Metro (recomendado con Expo Go en el mismo WiFi).
# Ejemplo dispositivo físico: EXPO_PUBLIC_API_URL="http://192.168.1.50:3000"
# EXPO_PUBLIC_API_URL="http://localhost:3000"
