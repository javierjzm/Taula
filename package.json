{
  "name": "taula",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=@taula/api",
    "dev:mobile": "turbo dev --filter=@taula/mobile",
    "dev:backoffice": "turbo dev --filter=@taula/backoffice",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:generate": "turbo db:generate --filter=@taula/api",
    "db:migrate": "turbo db:migrate --filter=@taula/api",
    "db:seed": "pnpm --filter=@taula/api run db:seed"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "prettier": "^3.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0"
  }
}
