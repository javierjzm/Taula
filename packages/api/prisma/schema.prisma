generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, postgis_topology, postgis_tiger_geocoder, fuzzystrmatch]
}

// ─── USUARIOS ────────────────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  avatar        String?
  phone         String?
  passwordHash  String?
  preferredLang String   @default("ca")
  authProvider  String   @default("email")
  googleId      String?  @unique
  appleId       String?  @unique
  pushToken         String?
  stripeCustomerId  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  reservations  Reservation[]
  reviews       Review[]
  notifications Notification[]
  ownerships    RestaurantOwner[]
  notifPreferences NotificationPreference?

  @@index([email])
  @@map("users")
}

// ─── RESTAURANTES ────────────────────────────────────────────────
model Restaurant {
  id                String    @id @default(cuid())
  name              String
  slug              String    @unique
  description       String?
  cuisineType       String[]
  priceRange        Int
  phone             String?
  email             String?
  website           String?
  address           String
  parish            Parish
  latitude          Float
  longitude         Float
  isActive          Boolean   @default(false)
  isFeatured        Boolean   @default(false)
  featuredUntil     DateTime?
  coverImage        String?
  images            String[]
  menuPdfUrl        String?
  avgRating         Float     @default(0)
  reviewCount       Int       @default(0)
  requiresApproval    Boolean   @default(false)
  minAdvanceMinutes   Int       @default(60)
  maxAdvanceDays      Int       @default(30)
  noShowProtection    Boolean   @default(false)
  noShowFeePerPerson  Float     @default(10)
  noShowGraceMins     Int       @default(15)
  stripeAccountId     String?
  externalReservationUrl String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  owners         RestaurantOwner[]
  hours          OpeningHours[]
  reservations   Reservation[]
  reviews        Review[]
  zones          Zone[]
  tables         RestaurantTable[]
  services       Service[]
  blockedDates   BlockedDate[]
  billing        BillingRecord[]
  menuCategories MenuCategory[]
  menuItems      MenuItem[]
  offers         Offer[]
  notifications  Notification[]
  subscription   Subscription?

  @@index([parish])
  @@index([isFeatured])
  @@index([isActive])
  @@map("restaurants")
}

enum Parish {
  ANDORRA_LA_VELLA
  ESCALDES_ENGORDANY
  ENCAMP
  CANILLO
  LA_MASSANA
  ORDINO
  SANT_JULIA_DE_LORIA
}

// ─── OWNERS (join table User <-> Restaurant) ─────────────────────
model RestaurantOwner {
  id           String     @id @default(cuid())
  userId       String
  restaurantId String
  role         OwnerRole  @default(OWNER)
  createdAt    DateTime   @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([userId])
  @@index([restaurantId])
  @@map("restaurant_owners")
}

enum OwnerRole {
  OWNER
  MANAGER
  STAFF
}

model OpeningHours {
  id           String     @id @default(cuid())
  restaurantId String
  dayOfWeek    Int
  openTime     String
  closeTime    String
  isClosed     Boolean    @default(false)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, dayOfWeek])
  @@map("opening_hours")
}

// ─── ZONAS Y MESAS ───────────────────────────────────────────────
model Zone {
  id           String @id @default(cuid())
  restaurantId String
  name         String
  sortOrder    Int    @default(0)

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tables     RestaurantTable[]

  @@index([restaurantId])
  @@map("zones")
}

model RestaurantTable {
  id           String  @id @default(cuid())
  restaurantId String
  zoneId       String
  label        String
  minCovers    Int     @default(1)
  maxCovers    Int
  isActive     Boolean @default(true)

  restaurant  Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  zone        Zone            @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  assignments TableAssignment[]

  @@index([restaurantId])
  @@index([zoneId])
  @@map("restaurant_tables")
}

// ─── SERVICIOS (COMIDA / CENA) ───────────────────────────────────
model Service {
  id           String  @id @default(cuid())
  restaurantId String
  name         String
  startTime    String
  endTime      String
  slotInterval Int     @default(30)
  turnDuration Int     @default(90)
  daysOfWeek   Int[]
  isActive     Boolean @default(true)

  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  blockedDates BlockedDate[]

  @@index([restaurantId])
  @@map("services")
}

// ─── DIAS BLOQUEADOS ─────────────────────────────────────────────
model BlockedDate {
  id           String   @id @default(cuid())
  restaurantId String
  date         DateTime @db.Date
  reason       String?
  isFullDay    Boolean  @default(true)
  serviceId    String?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  service    Service?   @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([restaurantId, date])
  @@map("blocked_dates")
}

// ─── ASIGNACION DE MESAS ─────────────────────────────────────────
model TableAssignment {
  id            String @id @default(cuid())
  reservationId String @unique
  tableId       String

  reservation Reservation    @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  table       RestaurantTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId])
  @@map("table_assignments")
}

// ─── RESERVAS ────────────────────────────────────────────────────
model Reservation {
  id                    String            @id @default(cuid())
  code                  String            @unique
  userId                String
  restaurantId          String
  date                  DateTime          @db.Date
  time                  String
  partySize             Int
  zoneId                String?
  specialRequests       String?
  status                ReservationStatus @default(CONFIRMED)
  cardGuarantee         Boolean           @default(false)
  stripePaymentMethodId String?
  stripePaymentIntentId String?
  noShowCharged         Boolean           @default(false)
  noShowAmount          Float?
  reminderSent24h       Boolean           @default(false)
  reminderSent2h        Boolean           @default(false)
  reviewRequested       Boolean           @default(false)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  user            User             @relation(fields: [userId], references: [id])
  restaurant      Restaurant       @relation(fields: [restaurantId], references: [id])
  tableAssignment TableAssignment?
  billing         BillingRecord?

  @@index([userId])
  @@index([restaurantId])
  @@index([date])
  @@map("reservations")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  ARRIVED
  NO_SHOW
  CANCELLED_USER
  CANCELLED_RESTAURANT
}

// ─── RESEÑAS ─────────────────────────────────────────────────────
model Review {
  id           String     @id @default(cuid())
  userId       String
  restaurantId String
  rating       Float
  comment      String?
  ownerReply   String?
  isVisible    Boolean    @default(true)
  createdAt    DateTime   @default(now())

  user       User       @relation(fields: [userId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([userId, restaurantId])
  @@index([restaurantId])
  @@map("reviews")
}

// ─── CARTA / MENÚ ───────────────────────────────────────────────
model MenuCategory {
  id           String @id @default(cuid())
  restaurantId String
  name         String
  description  String?
  sortOrder    Int    @default(0)
  isActive     Boolean @default(true)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items      MenuItem[]

  @@index([restaurantId])
  @@map("menu_categories")
}

model MenuItem {
  id           String  @id @default(cuid())
  restaurantId String
  categoryId   String
  name         String
  description  String?
  price        Float
  image        String?
  allergens    String[]
  tags         String[]
  isAvailable  Boolean @default(true)
  isPopular    Boolean @default(false)
  sortOrder    Int     @default(0)

  restaurant Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([categoryId])
  @@map("menu_items")
}

// ─── OFERTAS / DESCUENTOS ───────────────────────────────────────
model Offer {
  id           String    @id @default(cuid())
  restaurantId String
  title        String
  description  String?
  type         OfferType
  value        Float
  minCovers    Int       @default(1)
  daysOfWeek   Int[]
  startDate    DateTime? @db.Date
  endDate      DateTime? @db.Date
  startTime    String?
  endTime      String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([isActive])
  @@map("offers")
}

enum OfferType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_ITEM
  SPECIAL_MENU
}

// ─── NOTIFICACIONES IN-APP ────────────────────────────────────────
model Notification {
  id           String     @id @default(cuid())
  userId       String?
  restaurantId String?
  scope        NotifScope @default(USER)
  title        String
  body         String
  type         String     @default("general")
  data         Json?
  read         Boolean    @default(false)
  createdAt    DateTime   @default(now())

  user       User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([restaurantId, read])
  @@map("notifications")
}

enum NotifScope {
  USER
  RESTAURANT
}

model NotificationPreference {
  userId         String  @id
  confirmations  Boolean @default(true)
  reminders      Boolean @default(true)
  offers         Boolean @default(false)
  newReservation Boolean @default(true)
  cancellation   Boolean @default(true)
  newReview      Boolean @default(true)
  planAlerts     Boolean @default(true)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ─── PLANES Y SUSCRIPCIONES ──────────────────────────────────────
enum PlanType {
  RESERVATIONS
  LISTING_BASIC
  LISTING_FEATURED
}

enum SubscriptionStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  ADMIN_GRANT
}

model Subscription {
  id                   String             @id @default(cuid())
  restaurantId         String             @unique
  plan                 PlanType
  status               SubscriptionStatus @default(INCOMPLETE)
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  currentPeriodEnd     DateTime?
  adminGranted         Boolean            @default(false)
  adminGrantUntil      DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("subscriptions")
}

// ─── FACTURACIÓN ─────────────────────────────────────────────────
model BillingRecord {
  id            String        @id @default(cuid())
  restaurantId  String
  reservationId String        @unique
  amount        Float
  covers        Int
  status        BillingStatus @default(PENDING)
  createdAt     DateTime      @default(now())

  restaurant  Restaurant  @relation(fields: [restaurantId], references: [id])
  reservation Reservation @relation(fields: [reservationId], references: [id])

  @@map("billing_records")
}

enum BillingStatus {
  PENDING
  INVOICED
  PAID
}
