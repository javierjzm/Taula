{
  "name": "@taula/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "env-cmd -f ../../.env -- tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/packages/api/src/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "env-cmd -f ../../.env -- prisma migrate deploy",
    "db:migrate:dev": "env-cmd -f ../../.env -- prisma migrate dev",
    "db:migrate:prod": "env-cmd -f ../../.env -- prisma migrate deploy",
    "db:studio": "env-cmd -f ../../.env -- prisma studio",
    "db:seed": "env-cmd -f ../../.env -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.19.3",
    "@taula/shared": "workspace:*",
    "apple-signin-auth": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.74.1",
    "cloudinary": "^2.9.0",
    "date-fns": "^4.1.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "firebase-admin": "^13.8.0",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^3.3.11",
    "node-cron": "^4.2.1",
    "pino-pretty": "^13.1.3",
    "resend": "^6.12.0",
    "stripe": "^22.0.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "env-cmd": "^11.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
